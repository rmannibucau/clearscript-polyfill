{
  "name": "clearscript-polyfills",
  "version": "0.0.2",
  "description": "Polyfills for ClearScript to support AWS SDK and some browser APIs",
  "main": "dist/polyfills.bundle.js",
  "keywords": [
    "clearscript",
    "polyfill",
    "aws-sdk",
    "fetch",
    "crypto",
    "xmlhttprequest"
  ],
  "author": "Romain Manni-Bucau",
  "license": "Apache-2.0",
  "scripts": {
    "build": "esbuild ./index.js --bundle --format=iife --global-name=Polyfills --platform=browser --target=es2020 --outfile=dist/polyfills.bundle.js --minify",
    "build:sample": "esbuild ./sample/index.js --bundle --format=iife --global-name=AWS --platform=browser --target=es2020 --outfile=dist/aws-s3.bundle.js"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@xmldom/xmldom": "^0.8.11"
  },
  "devDependencies": {
    "esbuild": "^0.27.3"
  }
}
